# WanderPlot .env.local.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env.local and fill in your values.
# .env.local is git-ignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_32
NEXTAUTH_URL=http://localhost:3000

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "gemini" (default) or "openai" — changing this switches all LLM calls.
ACTIVE_LLM=gemini

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-pro           # accuracy-critical / prose (defaults to 1.5-pro)
# GEMINI_FAST_MODEL=gemini-1.5-flash    # high-frequency structured calls (defaults to GEMINI_MODEL)

# OpenAI (alternative — set ACTIVE_LLM=openai if using this)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# ── MongoDB Atlas (REQUIRED for full feature set) ─────────────────────────────
# Create free M0 cluster at https://cloud.mongodb.com
# Without this, the app falls back to the static 30 destinations (no crash).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wanderplot?retryWrites=true&w=majority

# ── Upstash Redis (OPTIONAL — first-tier cache for recommendations) ───────────
# Create a free serverless Redis at https://upstash.com
# Without this, the app uses only the MongoDB TTL cache.
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Google OAuth (OPTIONAL) ───────────────────────────────────────────────────
# Set up at https://console.cloud.google.com/apis/credentials
# Without this, email/password auth still works.
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret

# ── Google Places API (OPTIONAL) ─────────────────────────────────────────────
# Used ONLY for live ratings and photos at render time — never stored (ToS §6.4).
# Without this, cached ratings from Wikidata/OSM are shown.
# GOOGLE_PLACES_API_KEY=your_places_api_key

# ── Admin secret (protects /api/admin/ingest/* routes) ───────────────────────
# In dev with no secret set, ingest routes are open (warned in logs).
# SET THIS before deploying to production!
# ADMIN_SECRET=generate_a_strong_random_secret

# ── AI Engine tuning (sensible defaults in code — change to tune) ─────────────
# AI_DESTINATIONS_ENABLED=true        # set to false to disable Gemini generation entirely
# AI_CANDIDATE_COUNT=8                # how many AI-generated candidates to request per query
# RECO_CACHE_TTL_HOURS=6             # hours before cached recommendation sets expire
# INGEST_BATCH_SIZE=20               # destinations per ingestion batch (raise for faster seeding)
